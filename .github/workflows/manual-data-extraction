name: Data Pipeline - Extração Manual de CSVs

on:
  # 1. Permite rodar manualmente pelo botão no GitHub Actions
  workflow_dispatch:
    inputs:
      log_level:
        description: 'Nível de log (opcional)'
        required: false
        default: 'info'

  # 2. Roda automaticamente se alguém fizer push de CSVs na pasta downloads
  push:
    branches:
      - main  
    paths:
      - 'backend/downloads/*.csv'

jobs:
  extract-data:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout do código
        uses: actions/checkout@v3

      - name: Configurar Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18' # Ou a versão que você usa no projeto

      - name: Instalar dependências
        run: |
          cd backend
          npm install

      - name: Executar Extração dos CSVs
        env:
          DATABASE_URL: ${{ secrets.DATABASE_URL }}
        run: |
          cd backend
          # Garante que a pasta existe para não dar erro de leitura vazia
          mkdir -p downloads 
          node scripts/runExtractionFromCSV.js 
          # OBS: Certifique-se de que o caminho do script abaixo bate com onde você salvou a lógica de ler CSVs
          # Se a lógica estiver dentro do dataPipeline.js exportada como runExtractionFromCSV, crie um script curto ou chame direto:
          # node -e "require('./dataPipeline').runExtractionFromCSV()"
