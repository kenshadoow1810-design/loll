# Modelo de arquivo .env para produção
# Copie este arquivo para .env e preencha com seus dados

# Porta do servidor (opcional, o Render define automaticamente)
PORT=3001

# Configuração do banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Node environment
NODE_ENV=production

# URLs da API (se precisar de alguma URL específica)
API_URL=https://seusite.onrender.com
