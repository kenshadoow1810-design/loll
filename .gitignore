```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.css.map

# Environment variables
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.tox/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db
```